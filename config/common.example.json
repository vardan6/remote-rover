    "voltage_v": 22.56,
    "current_a": 10.0,
    "temperature_c": 17.0
  },
  "key_bindings": {
    "forward": ["arrow_up", "w"],
    "backward": ["arrow_down", "s"],
    "left": ["arrow_left", "a"],
    "right": ["arrow_right", "d"],
    "camera_toggle": ["v"]
  },
  "video": {
    "enabled": true,
    "ingest_mode": "mqtt_frames",
    "delivery_mode": "websocket_mjpeg"
  },
  "gcs": {
    "host": "127.0.0.1",
